#!/bin/bash

./bin/clean

javac -encoding UTF-8 -cp "lib/junit-platform-console-standalone-1.7.1.jar;lib/easymock-4.3.jar;lib/objenesis-3.2.jar;src" --source-path src -d dist src/*.java test/*.java

java --add-opens java.base/java.lang=ALL-UNNAMED -jar lib/junit-platform-console-standalone-1.7.1.jar -cp "dist;lib/easymock-4.3.jar;lib/objenesis-3.2.jar" --scan-class-path